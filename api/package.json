  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "azure-functions-core-tools": "^4.12.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "minimatch": "^8.0.7",
    "brace-expansion": "^2.1.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
